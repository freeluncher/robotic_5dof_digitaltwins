{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freeluncher.github.io/robotic_5dof_digitaltwins/contracts/esp32-hardware-input.schema.json",
  "title": "Esp32HardwareInput",
  "description": "ESP32 input envelope sent to backend containing metadata and 5 DOF joint data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "deviceId",
    "firmwareVersion",
    "sequence",
    "sentAtUtc",
    "transport",
    "payload"
  ],
  "properties": {
    "deviceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Unique hardware identifier from ESP32."
    },
    "firmwareVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32,
      "description": "Firmware version running on ESP32."
    },
    "sequence": {
      "type": "integer",
      "minimum": 0,
      "description": "Monotonic sequence number of telemetry packets."
    },
    "sentAtUtc": {
      "type": "string",
      "format": "date-time",
      "description": "UTC send timestamp generated by firmware."
    },
    "transport": {
      "type": "string",
      "enum": [
        "serial",
        "wifi"
      ],
      "description": "Physical transport from ESP32 to backend gateway."
    },
    "payload": {
      "$ref": "./raw-hardware-data.schema.json"
    },
    "checksumCrc16": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{4}$",
      "description": "Optional CRC16 checksum in hex format."
    }
  }
}
